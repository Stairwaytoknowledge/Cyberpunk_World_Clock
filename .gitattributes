# Normalize line endings across platforms.
# Without this, Windows collaborators produce CRLF diffs and git warns
# on every commit.
* text=auto eol=lf

# Scripts that Windows runs directly MUST keep CRLF or cmd/PowerShell
# misparses them.
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf
*.vbs  text eol=crlf

# Binary assets - never touch
*.ttf  binary
*.otf  binary
*.ico  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
*.zip  binary
*.ttc  binary
