# ============================================================
# World Clock - .gitignore
# Only files essential to running or distributing the app are
# tracked. Generated artifacts, user state, IDE files, and
# session debris stay out of git.
# ============================================================

# ---- Python -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.pytest_cache/

# ---- Virtual environments -----------------------------------
.venv/
venv/
env/
ENV/

# ---- Build outputs ------------------------------------------
# Everything produced by build_bundle.ps1, build_msix.ps1,
# generate_icons.py, or PyInstaller. These are regenerated on
# every release build.
dist/
build/WorldClock*/       # PyInstaller intermediate / onedir outputs
_bundle/                 # scratch dir used while iterating on the bundle
*.spec.bak

# ---- Generated icon assets ----------------------------------
# Regenerated by `python build/generate_icons.py`. CI runs this
# step before packaging the release, and Install.bat on end-user
# machines sees the icons inside the release zip.
# NOTE: assets/fonts/ is NOT ignored - Orbitron is shipped as a
# bundled resource (essential to the cyberpunk look) and needs
# to be in git.
assets/icon.ico
assets/icon.png
assets/store/

# ---- Dev-only preview snapshots -----------------------------
# _preview_*.png / _widget_preview*.png are throw-away renders
# we use to eyeball UI changes. Never commit.
_preview_*.png
_widget_preview*.png

# ---- User / runtime state -----------------------------------
# Written by the app at runtime. Contains local city selection
# and window position - machine-specific, never belongs in git.
config.json

# ---- Machine-specific shortcuts -----------------------------
# .lnk files bake in absolute paths so they don't travel between
# machines. `Create Shortcut.bat` regenerates them on demand.
*.lnk

# ---- Claude Code / AI tooling -------------------------------
.claude/
tmpclaude-*
tmpclaude-*-cwd

# ---- Editor / IDE -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Windows / pip stray artifacts --------------------------
# Things that sometimes appear from miskeyed shell redirections
# on Windows (e.g. `pip install pyqt6 >=6.6.0` creates a file
# literally named `=6.6.0`, and `del nul` under bash creates
# a file named `nul`).
nul
=*

# ---- MSIX sideload artifacts --------------------------------
# Local test certificates and intermediate MSIX outputs.
build/testcert.pfx
*.msix
*.appx
*.msixbundle
